    time        = 1, 1850, 1994, 1
/

&gcm_so_hist
    filename    = "ice_data/ISMIP6-2300/{domain}/{grid_name}/Ocean/NorESM1-M_RCP26-repeat/1850-1994/NorESM1-M_RCP26-repeat.nc"
    name        = "salinity"
    units       = "PSU" "PSU"
    scaling     = 1.0 0.0
    time        = 1, 1850, 1994, 1
/

&gcm_tf_hist
    filename    = "ice_data/ISMIP6-2300/{domain}/{grid_name}/Ocean/NorESM1-M_RCP26-repeat/1850-1994/NorESM1-M_RCP26-repeat.nc"
    name        = "thermal_forcing"
    units       = "K" "K"
    scaling     = 1.0 0.0
    time        = 1, 1850, 1994, 1
/

&gcm_to_proj
    filename    = "ice_data/ISMIP6-2300/{domain}/{grid_name}/Ocean/{gcm}_{scenario}/1995-2300/{gcm}_{scenario}.nc"
    name        = "temperature"
    units       = "degrees C" "K"
    scaling     = 1.0 273.15
    time        = 1, 1995, 2300, 1
/

&gcm_so_proj
    filename    = "ice_data/ISMIP6-2300/{domain}/{grid_name}/Ocean/{gcm}_{scenario}/1995-2300/{gcm}_{scenario}.nc"
    name        = "salinity"
