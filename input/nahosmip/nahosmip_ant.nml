================== Ice shelf collapse mask =================

&gcm_mask_shlf_proj
    filename    = "ice_data/ISMIP6-2300/{domain}/{grid_name}/ShelfCollapse_forcing/{gcm}_{scenario}/1995-2300/{gcm}_{scenario}.nc"
    name        = "mask"
    units       = "1" "1"
    scaling     = 1.0 0.0
    time        = 1, 1995, 2300, 1
/
